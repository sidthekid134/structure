{
  "name": "credential-vault",
  "version": "1.0.0",
  "description": "Encrypted credential vault and secret management",
  "main": "dist/index.js",
  "scripts": {
    "ui:install": "npm --prefix studio-ui install",
    "ui:dev": "npm --prefix studio-ui run dev",
    "ui:watch": "npm --prefix studio-ui run build -- --watch",
    "ui:build": "npm --prefix studio-ui run build",
    "build:backend": "tsc && mkdir -p dist/studio/static && cp -R src/studio/static/. dist/studio/static",
    "build": "npm run ui:build && npm run build:backend",
    "dev:backend": "STUDIO_DEV_MODE=1 tsc-watch --preserveWatchOutput --onSuccess \"node dist/studio/server.js\"",
    "dev:full": "concurrently -k -n backend,ui -c cyan,magenta \"npm run dev:backend\" \"npm run ui:watch\"",
    "prod:backend": "npm run build:backend && node dist/studio/server.js",
    "prod:ui": "npm run ui:build && npm --prefix studio-ui run preview -- --host 127.0.0.1 --port 4173",
    "test": "jest --testPathPattern='src/__tests__'",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^9.2.1",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "dependencies": {
    "@expo/apple-utils": "^2.1.21",
    "@octokit/rest": "^18.12.0",
    "@types/libsodium-wrappers": "^0.8.2",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.6.2",
    "jszip": "^3.10.1",
    "libsodium-wrappers": "^0.8.2",
    "ws": "^8.16.0"
  }
}
