{
  "name": "credential-vault",
  "version": "1.0.0",
  "description": "Encrypted credential vault and secret management",
  "main": "dist/index.js",
  "scripts": {
    "ui:install": "npm --prefix studio-ui install",
    "ui:dev": "npm --prefix studio-ui run dev",
    "ui:build": "npm --prefix studio-ui run build",
    "build": "npm run ui:build && tsc && mkdir -p dist/studio/static && cp -R src/studio/static/. dist/studio/static",
    "test": "jest --testPathPattern='src/__tests__'",
    "typecheck": "tsc --noEmit",
    "studio": "npm run build && node dist/studio/server.js",
    "studio:dev": "npm run build && STUDIO_DEV_MODE=1 node dist/studio/server.js"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "ws": "^8.16.0"
  }
}
